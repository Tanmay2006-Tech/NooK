# Copy to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL (required for API server and db push)
DATABASE_URL=postgres://user:password@localhost:5432/nook

# API server port
PORT=8080

# Frontend dev server port (nook — separate from API)
NOOK_PORT=5173

# Where the frontend is served from (usually /)
BASE_PATH=/

# Backend URL for Vite dev proxy (forwards /api/* to this host)
API_URL=http://localhost:8080

# Optional
# LOG_LEVEL=info
# NODE_ENV=development
